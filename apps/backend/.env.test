# Test Database Configuration
DATABASE_URL="postgresql://test_user:test_password@localhost:5440/chardb_test"

# JWT Configuration
JWT_SECRET="test-jwt-secret-key-for-testing-only"
JWT_REFRESH_SECRET="test-refresh-secret-key-for-testing-only"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Test Environment
NODE_ENV="test"

# CORS Configuration
CORS_ORIGIN="http://localhost:3000"

# Rate Limiting (disabled for tests)
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=1000

# Discord (mock values — bot calls will fail gracefully in tests)
DISCORD_BOT_TOKEN="test-discord-bot-token"
DISCORD_CLIENT_ID="000000000000000001"
DISCORD_CLIENT_SECRET="test-discord-client-secret"
DISCORD_GUILD_ID="000000000000000002"

# DeviantArt OAuth (mock values)
DEVIANTART_CLIENT_ID="test-deviantart-client-id"
DEVIANTART_CLIENT_SECRET="test-deviantart-client-secret"

# AWS / S3 (mock values — no real uploads in tests)
AWS_REGION="us-east-1"
AWS_S3_BUCKET="chardb-test"
AWS_ACCESS_KEY_ID="test-access-key"
AWS_SECRET_ACCESS_KEY="test-secret-key"
AWS_ENDPOINT_URL="http://localhost:4566"

# SQS (disabled for tests)
AWS_SQS_ENABLED="false"
AWS_SQS_QUEUE_URL="http://localhost:4566/000000000000/test-queue"

# Email (disabled for tests)
MAIL_HOST="localhost"
MAIL_PORT=1025
MAIL_FROM="test@chardb.test"